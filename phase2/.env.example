# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# ── Your API key — share this with the mobile team ──────────────────────────
API_KEY=your-strong-secret-key-here

# ── VLM ─────────────────────────────────────────────────────────────────────
VLM_MODEL=llava:7b

# ── Mobile team's backend — where we push verified alerts ───────────────────
# Ask the mobile team for their alert webhook endpoint and token
ALERT_WEBHOOK_URL=https://their-backend.com/api/safety-alerts
ALERT_WEBHOOK_TOKEN=their-bearer-token-if-required

# ── Storage ──────────────────────────────────────────────────────────────────
DB_PATH=/data/events.db
LOG_FILE=/data/logs/driver_safety.log
EVIDENCE_DIR=/data/evidence
REVIEW_DIR=/data/review
FALSE_DETECTIONS_DIR=/data/false_detections
