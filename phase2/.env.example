# ─────────────────────────────────────────────────────────────────────────────
# Driver Safety AI — Phase 2  |  Copy to .env and fill in real values
# .env is gitignored — NEVER commit it
# ─────────────────────────────────────────────────────────────────────────────

# ── YOUR API key — generate once, share with mobile team ─────────────────────
# Run:  python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-strong-secret-key-here

# ── VLM (Ollama running on same EC2 instance) ─────────────────────────────────
VLM_MODEL=llava:7b

# ── Mobile team's backend (proximity-driver-api) ──────────────────────────────
# Base URL — already known
MOBILE_API_BASE_URL=https://proximity-driver-api.prod-app.in

# Driver lookup path  →  GET {MOBILE_API_BASE_URL}{DRIVER_LOOKUP_PATH}/{deviceTabletId}
DRIVER_LOOKUP_PATH=/api/drivers/by-device

# Their API key if their backend requires auth on the driver lookup endpoint
MOBILE_API_KEY=

# ── Alert webhook — ASK MOBILE TEAM for this endpoint ────────────────────────
# When VLM confirms a detection (verified=true), we POST the alert here.
# Ask the mobile team: "What endpoint should we hit when we detect phone/smoking?"
ALERT_WEBHOOK_URL=https://proximity-driver-api.prod-app.in/api/FILL_THIS_IN
ALERT_WEBHOOK_TOKEN=

# ── Storage (inside Docker /data volume) ──────────────────────────────────────
DB_PATH=/data/events.db
LOG_FILE=/data/logs/driver_safety.log
EVIDENCE_DIR=/data/evidence
REVIEW_DIR=/data/review
FALSE_DETECTIONS_DIR=/data/false_detections
